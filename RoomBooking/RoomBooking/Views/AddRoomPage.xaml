<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RoomBooking.Views.AddRoomPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" BackgroundColor="#2563EB" HeightRequest="80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="←" BackgroundColor="Transparent" TextColor="White" FontSize="30"
                    FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"
                    WidthRequest="60" HeightRequest="60" Margin="0,0,0,7" Clicked="OnBackClicked"/>
            <Label Grid.Column="1" Text="เพิ่มห้องใหม่" FontSize="20" FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="8">

                <!-- รูปภาพ -->
                <Frame CornerRadius="10" BorderColor="#E0E0E0" HeightRequest="160" HasShadow="False"
                       BackgroundColor="#F8F9FA" Margin="0,0,0,6" Padding="0">
                    <Grid>
                        <Image x:Name="imgPreview" Aspect="AspectFill" IsVisible="False"/>
                        <VerticalStackLayout x:Name="stackUploadInfo" VerticalOptions="Center"
                                             HorizontalOptions="Center" Spacing="8">
                            <Label Text="📷 เพิ่มรูปภาพห้อง" FontSize="15" TextColor="#2563EB"
                                   HorizontalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPickImageTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPickImageTapped"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Frame>

                <Label Text="ชื่อห้อง" FontSize="14" FontAttributes="Bold" TextColor="#111"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10"
                        BackgroundColor="White" Margin="0,0,0,6">
                    <Entry x:Name="entryRoomName" Placeholder="เช่น Meeting Room A" FontSize="14" Margin="10,8"/>
                </Border>

                <Label Text="จำนวนความจุ (คน)" FontSize="14" FontAttributes="Bold" TextColor="#111"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10"
                        BackgroundColor="White" Margin="0,0,0,6">
                    <Entry x:Name="entryCapacity" Placeholder="ระบุจำนวนคน" Keyboard="Numeric"
                           FontSize="14" Margin="10,8"/>
                </Border>

                <Label Text="ราคา (บาท/ชม.)" FontSize="14" FontAttributes="Bold" TextColor="#111"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10"
                        BackgroundColor="White" Margin="0,0,0,6">
                    <Entry x:Name="entryPrice" Placeholder="ระบุราคาต่อชั่วโมง" Keyboard="Numeric"
                           FontSize="14" Margin="10,8"/>
                </Border>

                <Label Text="อุปกรณ์ภายในห้อง" FontSize="14" FontAttributes="Bold" TextColor="#111" Margin="0,5,0,0"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10"
                        BackgroundColor="White" Margin="0,0,0,6">
                    <Editor x:Name="editorEquipment" Placeholder="เช่น โปรเจคเตอร์, ไวท์บอร์ด, ปลั๊กไฟ..."
                            FontSize="14" HeightRequest="80" Margin="10,8"/>
                </Border>

                <Label Text="ค่าประกันความเสียหาย" FontSize="14" FontAttributes="Bold" TextColor="#111"/>
                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 10"
                        BackgroundColor="White" Margin="0,0,0,6">
                    <Entry x:Name="entryInsurance" Placeholder="ระบุค่าประกัน" Keyboard="Numeric"
                           FontSize="14" Margin="10,8"/>
                </Border>

                <BoxView HeightRequest="1" Color="#F0F0F0" Margin="0,10"/>

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <Label Grid.Column="0" Text="เปิดให้จองทันที" FontSize="14"
                           FontAttributes="Bold" TextColor="#111" VerticalOptions="Center"/>
                    <Switch Grid.Column="1" x:Name="switchAvailable" IsToggled="True" OnColor="#10B981"/>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <Label Grid.Column="0" Text="แสดงในรายการแนะนำ" FontSize="14"
                           FontAttributes="Bold" TextColor="#111" VerticalOptions="Center"/>
                    <Switch Grid.Column="1" x:Name="switchRecommended" IsToggled="False" OnColor="#2563EB"/>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <Label Grid.Column="0" Text="ปิดปรับปรุง" FontSize="14"
                           FontAttributes="Bold" TextColor="#111" VerticalOptions="Center"/>
                    <Switch Grid.Column="1" x:Name="switchMaintenance" IsToggled="False" OnColor="#2563EB"/>
                </Grid>

                <Label x:Name="lblError" TextColor="#EF4444" FontSize="13" IsVisible="False"
                       HorizontalOptions="Center" Margin="0,10,0,0"/>

                <Button Text="บันทึกและสร้างห้อง" BackgroundColor="#2563EB" TextColor="White" FontSize="16"
                        FontAttributes="Bold" CornerRadius="12" HeightRequest="56" Margin="0,10,0,20"
                        Clicked="btnNext_Clicked">
                    <Button.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.1"/>
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
