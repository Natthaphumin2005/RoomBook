<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:RoomBooking.Converters"
             x:Class="RoomBooking.Views.RoomDetailPopup"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#80000000">

    <ContentPage.Resources>
        <conv:Base64ToImageConverter x:Key="Base64ToImage"/>
    </ContentPage.Resources>

    <Grid>
        <BoxView BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackgroundTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <Frame CornerRadius="20"
               Padding="0"
               Margin="20,40" 
               BackgroundColor="White"
               HasShadow="True"
               VerticalOptions="Center"
               HeightRequest="650">

            <Grid RowDefinitions="Auto,*,Auto">

                <Grid Grid.Row="0" HeightRequest="48">
                    <Button Text="✕" BackgroundColor="Transparent" TextColor="#111827"
                            FontSize="18" HorizontalOptions="End" VerticalOptions="Center"
                            WidthRequest="48" Clicked="OnCloseTapped"/>
                    <Label Text="รายละเอียด" FontSize="18" FontAttributes="Bold" 
                           TextColor="#111827" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="0">
                        <Grid HeightRequest="200">
                            <Image Source="{Binding ImagePath, Converter={StaticResource Base64ToImage}}" Aspect="AspectFill"/>
                            <Frame CornerRadius="15" Padding="12,4" HorizontalOptions="End" 
                                   VerticalOptions="Start" Margin="10" HasShadow="False"
                                   BackgroundColor="{Binding StatusColorHex}">
                                <Label Text="{Binding StatusText}" FontSize="12" TextColor="White" FontAttributes="Bold"/>
                            </Frame>
                        </Grid>

                        <VerticalStackLayout Padding="20,15" Spacing="8">
                            <Label Text="{Binding RoomDisplayName}" FontSize="20" FontAttributes="Bold" TextColor="#111827"/>
                            <Label Text="{Binding CapacityText}" FontSize="14" TextColor="#666666"/>

                            <VerticalStackLayout Spacing="2" Margin="0,5">
                                <Label Text="{Binding PriceDisplayText}" FontSize="15" FontAttributes="Bold" TextColor="#2563EB"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10"/>

                            <Label Text="อุปกรณ์ในห้อง" FontSize="16" FontAttributes="Bold" TextColor="#111827"/>
                            <Label Text="{Binding Equipment}" FontSize="14" TextColor="#444444" Margin="0,0,0,15"/>

                            <Label Text="ค่าประกันความเสียหาย" FontSize="16" FontAttributes="Bold" TextColor="#111827"/>
                            <Label Text="{Binding InsuranceAmount}" FontSize="14" TextColor="#444444" Margin="0,0,0,20"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <Grid Grid.Row="2" ColumnDefinitions="*,*" Padding="20,15" ColumnSpacing="15" BackgroundColor="White">
                    <Button Grid.Column="0" Text="แก้ไข" BackgroundColor="#2563EB" 
                            TextColor="White" FontSize="15" FontAttributes="Bold"
                            CornerRadius="10" HeightRequest="48" Clicked="OnEditClicked"/>
                    <Button Grid.Column="1" Text="ลบ" BackgroundColor="#EF4444" 
                            TextColor="White" FontSize="15" FontAttributes="Bold"
                            CornerRadius="10" HeightRequest="48" Clicked="OnDeleteClicked"/>
                </Grid>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
